###############################################################################
# WordPress Custom Theme Repository
# Ignore everything by default, then whitelist only required project files.
###############################################################################

# Ignore everything
*

###############################################################################
# Repository Files
###############################################################################

!.gitignore
!README.md
!LICENSE
!.editorconfig
!.gitattributes

###############################################################################
# WordPress Configuration
###############################################################################

# Never commit production configuration
wp-config.php

# Track the sample configuration
!wp-config-sample.php

###############################################################################
# Track wp-content
###############################################################################

!wp-content/
wp-content/*

###############################################################################
# Themes
###############################################################################

!wp-content/themes/
wp-content/themes/*

# Keep only the custom theme
!wp-content/themes/pride-of-africa/
!wp-content/themes/pride-of-africa/**

###############################################################################
# Plugins
###############################################################################

!wp-content/plugins/
wp-content/plugins/*

# Uncomment if you create your own plugins
#!wp-content/plugins/my-custom-plugin/
#!wp-content/plugins/my-custom-plugin/**

###############################################################################
# MU Plugins
###############################################################################

!wp-content/mu-plugins/
!wp-content/mu-plugins/**

###############################################################################
# Ignore Generated WordPress Content
###############################################################################

wp-content/uploads/
wp-content/cache/
wp-content/upgrade/
wp-content/backups/
wp-content/ai1wm-backups/

###############################################################################
# Composer
###############################################################################

vendor/
composer.phar

###############################################################################
# Node / Frontend Build
###############################################################################

node_modules/
dist/
build/
coverage/

###############################################################################
# Environment Files
###############################################################################

.env
.env.*
!.env.example

###############################################################################
# PHP Tools
###############################################################################

.phpunit.result.cache
.php-cs-fixer.cache
.phpstan/
.psalm/

###############################################################################
# IDEs
###############################################################################

.idea/

.vscode/*
!.vscode/extensions.json

###############################################################################
# Operating System Files
###############################################################################

# macOS
.DS_Store

# Windows
Thumbs.db
Desktop.ini
$RECYCLE.BIN/

###############################################################################
# Archives
###############################################################################

*.zip
*.tar
*.gz
*.7z
*.rar

###############################################################################
# Database Dumps
###############################################################################

*.sql
*.sqlite
*.bak

###############################################################################
# Logs
###############################################################################

*.log
error_log
debug.log

###############################################################################
# Temporary Files
###############################################################################

*.tmp
*.temp
*.swp
*.swo
*.orig

###############################################################################
# Miscellaneous
###############################################################################

.cache/
tmp/
temp/